# ================================================================
# SwiftSMS — Environment Variables
# 1. Copy this:  cp .env.example .env
# 2. Fill values below
# 3. NEVER push .env to GitHub — .gitignore protects it
# ================================================================

# Server port (Render sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production

# ---- TWILIO (get from console.twilio.com) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ---- RENDER (copy from your Render dashboard URL) ----
# Example: https://swiftsms-api.onrender.com
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# ---- DEMO KEY (change this to anything secret) ----
DEMO_API_KEY=sms_change_this_to_something_secret
